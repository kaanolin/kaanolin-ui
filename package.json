{
  "name": "@kaanolin/root",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx,css}\"",
    "release": "npm version --workspace=packages/react",
    "postversion": "git push && git push --tags"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@nx/docker": "22.4.5",
    "@nx/jest": "22.4.5",
    "@nx/storybook": "22.4.5",
    "@nx/vite": "22.4.5",
    "@nx/web": "22.4.5",
    "@testing-library/dom": "^10.4.1",
    "@vitest/ui": "^4.0.0",
    "eslint": "^9.39.2",
    "jest": "^30.0.2",
    "jiti": "2.4.2",
    "nx": "22.4.5",
    "prettier": "^3.8.1",
    "storybook": "8.5.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.0.0",
    "vitest": "^4.0.0"
  }
}
