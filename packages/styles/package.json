{
  "name": "@kaanolin/styles",
  "version": "0.1.0",
  "description": "Design tokens and theme for @kaanolin (Tailwind CSS v4)",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "style": "./dist/index.css",
  "exports": {
    ".": {
      "style": "./dist/index.css",
      "default": "./dist/index.css"
    },
    "./index.css": "./dist/index.css",
    "./css": "./dist/index.css",
    "./colors": {
      "style": "./src/colors.css",
      "default": "./src/colors.css"
    },
    "./typography": {
      "style": "./src/typography.css",
      "default": "./src/typography.css"
    },
    "./shadows": {
      "style": "./src/shadows.css",
      "default": "./src/shadows.css"
    },
    "./spacing": {
      "style": "./src/spacing.css",
      "default": "./src/spacing.css"
    }
  },
  "sideEffects": ["**/*.css"],
  "scripts": {
    "build": "mkdir -p dist && cat src/colors.css src/typography.css src/shadows.css src/spacing.css > dist/index.css"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  }
}
