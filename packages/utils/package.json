{
  "name": "@kaanolin/utils",
  "version": "0.1.0",
  "description": "Utility functions for @kaanolin (cx, sortCx)",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./dist/utils.cjs",
  "module": "./dist/utils.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "nx vite:build",
    "dev": "nx vite:build --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "typescript": "5.7.3",
    "vite": "6.0.11",
    "vite-plugin-dts": "4.5.0"
  }
}
